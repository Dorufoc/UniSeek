<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.uniseek.dao.TaskMapper">

    <!-- Task 实体基础映射 -->
    <resultMap id="BaseResultMap" type="com.uniseek.entity.Task">
        <id column="id" property="id"/>
        <result column="enterprise_id" property="enterpriseId"/>
        <result column="category_id" property="categoryId"/>
        <result column="region_id" property="regionId"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="salary_min" property="salaryMin"/>
        <result column="salary_max" property="salaryMax"/>
        <result column="salary_unit" property="salaryUnit"/>
        <result column="job_type" property="jobType"/>
        <result column="total_quota" property="totalQuota"/>
        <result column="remaining_quota" property="remainingQuota"/>
        <result column="address" property="address"/>
        <result column="tag" property="tag"/>
        <result column="longitude" property="longitude"/>
        <result column="latitude" property="latitude"/>
        <result column="status" property="status"/>
        <result column="reject_reason" property="rejectReason"/>
        <result column="version" property="version"/>
        <result column="deadline" property="deadline"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- TaskVO 映射（含关联字段） -->
    <resultMap id="TaskVOResultMap" type="com.uniseek.dto.TaskVO">
        <id column="id" property="id"/>
        <result column="enterprise_id" property="enterpriseId"/>
        <result column="category_id" property="categoryId"/>
        <result column="region_id" property="regionId"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="salary_min" property="salaryMin"/>
        <result column="salary_max" property="salaryMax"/>
        <result column="salary_unit" property="salaryUnit"/>
        <result column="job_type" property="jobType"/>
        <result column="total_quota" property="totalQuota"/>
        <result column="remaining_quota" property="remainingQuota"/>
        <result column="address" property="address"/>
        <result column="tag" property="tag"
                typeHandler="com.uniseek.common.handler.StringListTypeHandler"/>
        <result column="longitude" property="longitude"/>
        <result column="latitude" property="latitude"/>
        <result column="status" property="status"/>
        <result column="reject_reason" property="rejectReason"/>
        <result column="deadline" property="deadline"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="enterprise_name" property="enterpriseName"/>
        <result column="category_name" property="categoryName"/>
        <result column="region_name" property="regionName"/>
        <result column="has_applied" property="hasApplied"/>
        <result column="application_id" property="applicationId"/>
        <result column="application_count" property="applicationCount"/>
        <result column="has_favorited" property="hasFavorited"/>
        <result column="hr_name" property="hrName"/>
        <result column="hr_avatar" property="hrAvatar"/>
        <result column="is_owner" property="isOwner"/>
    </resultMap>

    <!-- 通用 SELECT 片段：LEFT JOIN 企业/分类/地区/用户 -->
    <sql id="joinTaskRelations">
        FROM task
        LEFT JOIN enterprise ON task.enterprise_id = enterprise.id
        LEFT JOIN user ON enterprise.user_id = user.id
        LEFT JOIN category ON task.category_id = category.id
        LEFT JOIN region ON task.region_id = region.id
    </sql>

    <!-- 通用查询字段 -->
    <sql id="selectTaskFields">
        task.id, task.enterprise_id, task.category_id, task.region_id,
        task.title, task.description,
        task.salary_min, task.salary_max, task.salary_unit,
        task.job_type, task.total_quota, task.remaining_quota,
        task.address, task.tag, task.longitude, task.latitude,
        task.status, task.reject_reason, task.deadline, task.create_time, task.update_time,
        enterprise.company_name AS enterprise_name,
        category.name AS category_name,
        region.name AS region_name,
        user.nickname AS hr_name,
        user.avatar_url AS hr_avatar
    </sql>

    <!-- 热门排序子查询（仅 sortBy=popular 时启用） -->
    <sql id="joinPopularSubquery">
        <if test="req.sortBy == 'popular'">
            LEFT JOIN (
                SELECT task_id, COUNT(*) AS c
                FROM task_application
                GROUP BY task_id
            ) AS apps ON task.id = apps.task_id
        </if>
    </sql>

    <!-- 搜索条件 WHERE -->
    <sql id="searchConditions">
        <where>
            <if test="req.keyword != null and req.keyword != ''">
                AND task.title REGEXP #{req.keywordRegex}
            </if>
            <if test="req.categoryIds != null and req.categoryIds != ''">
                AND task.category_id IN
                <foreach item="id" collection="req.categoryIds.split(',')" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
            <if test="req.categoryId != null and (req.categoryIds == null or req.categoryIds == '')">
                AND task.category_id = #{req.categoryId}
            </if>
            <if test="req.regionIds != null and req.regionIds != ''">
                AND task.region_id IN
                <foreach item="id" collection="req.regionIds.split(',')" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
            <if test="req.regionId != null and (req.regionIds == null or req.regionIds == '')">
                AND task.region_id = #{req.regionId}
            </if>
            <if test="req.jobType != null">
                AND task.job_type = #{req.jobType}
            </if>
            <if test="req.salaryMin != null or req.salaryMax != null">
                <choose>
                    <when test="req.includeNegotiable != null and req.includeNegotiable">
                        AND (
                            (task.salary_min = 0 AND task.salary_max = 0)
                            <if test="req.salaryMin != null">
                                OR (task.salary_min >= #{req.salaryMin}
                                <if test="req.salaryMax != null">
                                    AND task.salary_max &lt;= #{req.salaryMax}
                                </if>
                                )
                            </if>
                            <if test="req.salaryMin == null and req.salaryMax != null">
                                OR task.salary_max &lt;= #{req.salaryMax}
                            </if>
                        )
                    </when>
                    <otherwise>
                        <if test="req.salaryMin != null">AND task.salary_min >= #{req.salaryMin}</if>
                        <if test="req.salaryMax != null">AND task.salary_max &lt;= #{req.salaryMax}</if>
                        AND NOT (task.salary_min = 0 AND task.salary_max = 0)
                    </otherwise>
                </choose>
            </if>
            <if test="req.salaryUnit != null">
                AND task.salary_unit = #{req.salaryUnit}
            </if>
            <if test="req.address != null and req.address != ''">
                AND task.address LIKE CONCAT('%', #{req.address}, '%')
            </if>
            <if test="req.tags != null and req.tags != ''">
                <foreach item="t" collection="req.tagsArray">
                    AND task.tag LIKE CONCAT('%', #{t}, '%')
                </foreach>
            </if>
            <!-- 只查询招聘中的职位（1），已满员/已下架的职位不展示 -->
            AND task.status = 1
            <!-- 过滤已过截止时间的职位 -->
            AND (task.deadline IS NULL OR task.deadline &gt; NOW())
        </where>
    </sql>

    <!-- 排序 -->
    <sql id="orderByClause">
        <bind name="orderDir" value="req.sortOrder == 'asc' ? 'ASC' : 'DESC'" />
        <choose>
            <when test="req.sortBy == 'popular'">
                ORDER BY apps.c DESC, task.create_time DESC
            </when>
            <when test="req.sortBy == 'salary_max'">
                ORDER BY task.salary_max ${orderDir}, task.create_time DESC
            </when>
            <otherwise>
                ORDER BY task.create_time ${orderDir}
            </otherwise>
        </choose>
    </sql>

    <!-- 分页条件搜索 -->
    <select id="selectPageByCondition" resultMap="TaskVOResultMap">
        SELECT
        <include refid="selectTaskFields"/>
        <if test="req.sortBy == 'popular'">
            , COALESCE(apps.c, 0) AS application_count
        </if>
        <include refid="joinTaskRelations"/>
        <include refid="joinPopularSubquery"/>
        <include refid="searchConditions"/>
        <include refid="orderByClause"/>
    </select>

    <!-- 查询职位详情（含 hasApplied、applicationId、hasFavorited、isOwner） -->
    <select id="selectDetailById" resultMap="TaskVOResultMap">
        SELECT
        <include refid="selectTaskFields"/>,
        CASE WHEN ta.id IS NOT NULL THEN 1 ELSE 0 END AS has_applied,
        ta.id AS application_id,
        COALESCE(apps.c, 0) AS application_count,
        CASE WHEN f.id IS NOT NULL THEN 1 ELSE 0 END AS has_favorited,
        CASE WHEN enterprise.user_id = #{userId} THEN 1 ELSE 0 END AS is_owner
        <include refid="joinTaskRelations"/>
        LEFT JOIN task_application ta ON ta.task_id = task.id AND ta.applicant_id = #{userId}
        LEFT JOIN (
            SELECT task_id, COUNT(*) AS c
            FROM task_application
            GROUP BY task_id
        ) AS apps ON task.id = apps.task_id
        LEFT JOIN favorite f ON f.task_id = task.id AND f.user_id = #{userId}
        WHERE task.id = #{id}
    </select>

    <!-- 查询本企业职位列表 -->
    <select id="selectEnterpriseTasks" resultMap="TaskVOResultMap">
        SELECT
        <include refid="selectTaskFields"/>,
        COALESCE(apps.c, 0) AS application_count
        <include refid="joinTaskRelations"/>
        LEFT JOIN (
            SELECT task_id, COUNT(*) AS c
            FROM task_application
            GROUP BY task_id
        ) AS apps ON task.id = apps.task_id
        WHERE task.enterprise_id = #{enterpriseId}
        AND NOT (task.status = 5 AND EXISTS (
            SELECT 1 FROM task t2
            WHERE t2.enterprise_id = task.enterprise_id
            AND t2.title = task.title
            AND t2.id != task.id
            AND t2.status != 5
        ))
        ORDER BY task.create_time DESC
    </select>

    <!-- 管理后台分页查询职位列表（LEFT JOIN enterprise 获取企业名称） -->
    <select id="selectAdminTaskPage" resultMap="BaseResultMap">
        SELECT task.*, enterprise.company_name AS enterprise_name
        FROM task
        LEFT JOIN enterprise ON task.enterprise_id = enterprise.id
        <where>
            <if test="status != null">
                AND task.status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND task.title LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="rejected != null and rejected">
                AND task.status = 5
            </if>
            <if test="rejected != null and !rejected">
                AND task.status != 5
            </if>
        </where>
        ORDER BY task.id ASC
    </select>

    <!-- 获取所有职位标签（去重），仅包含招聘中的职位 -->
    <select id="selectAllTags" resultType="string">
        SELECT DISTINCT jt.tag_value
        FROM task t,
        JSON_TABLE(t.tag, '$[*]' COLUMNS (tag_value VARCHAR(255) PATH '$')) AS jt
        WHERE t.tag IS NOT NULL AND t.tag != '' AND t.status = 1
        ORDER BY jt.tag_value
    </select>

    <!-- 查询指定企业的已发布职位（供求职者查看） -->
    <select id="selectPublishedEnterpriseTasks" resultMap="TaskVOResultMap">
        SELECT
        <include refid="selectTaskFields"/>,
        COALESCE(apps.c, 0) AS application_count
        <include refid="joinTaskRelations"/>
        LEFT JOIN (
            SELECT task_id, COUNT(*) AS c
            FROM task_application
            GROUP BY task_id
        ) AS apps ON task.id = apps.task_id
        WHERE task.enterprise_id = #{enterpriseId} AND task.status = 1
        ORDER BY task.create_time DESC
    </select>

</mapper>
