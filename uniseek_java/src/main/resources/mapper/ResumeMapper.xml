<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.uniseek.dao.ResumeMapper">

    <resultMap id="BaseResultMap" type="com.uniseek.entity.Resume">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="gender" property="gender"/>
        <result column="birth_date" property="birthDate"/>
        <result column="education" property="education"/>
        <result column="school" property="school"/>
        <result column="skills" property="skills"/>
        <result column="experience" property="experience"/>
        <result column="attachment_url" property="attachmentUrl"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 带实名信息的简历结果映射（继承 BaseResultMap 并追加 realName） -->
    <resultMap id="ResumeWithRealNameMap" extends="BaseResultMap" type="com.uniseek.entity.Resume">
        <result column="real_name" property="realName"/>
    </resultMap>

    <!-- 查询简历及实名信息（LEFT JOIN real_name_auth 获取 realName） -->
    <select id="selectResumeWithRealName" resultMap="ResumeWithRealNameMap">
        SELECT r.*, rn.real_name
        FROM resume r
        LEFT JOIN real_name_auth rn ON r.user_id = rn.user_id AND rn.status = 1
        WHERE r.user_id = #{userId}
    </select>

</mapper>
