<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.uniseek.dao.ChatMessageMapper">

    <resultMap id="BaseResultMap" type="com.uniseek.entity.ChatMessage">
        <id column="id" property="id"/>
        <result column="session_id" property="sessionId"/>
        <result column="sender_id" property="senderId"/>
        <result column="message_type" property="messageType"/>
        <result column="content" property="content"/>
        <result column="is_read" property="isRead"/>
        <result column="send_time" property="sendTime"/>
    </resultMap>

    <!-- 游标分页查询历史消息（按 id 降序，取小于 beforeId 的 pageSize 条） -->
    <select id="selectMessagesBeforeId" resultMap="BaseResultMap">
        SELECT id, session_id, sender_id, message_type, content, is_read, send_time
        FROM chat_message
        WHERE session_id = #{sessionId} AND id &lt; #{beforeId}
        ORDER BY id DESC
        LIMIT #{pageSize}
    </select>

    <!-- 查询最新的一批消息（首次加载） -->
    <select id="selectLatestMessages" resultMap="BaseResultMap">
        SELECT id, session_id, sender_id, message_type, content, is_read, send_time
        FROM chat_message
        WHERE session_id = #{sessionId}
        ORDER BY id DESC
        LIMIT #{pageSize}
    </select>

    <!-- 统计未读消息数 -->
    <select id="countUnread" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM chat_message
        WHERE session_id = #{sessionId} AND is_read = 0 AND sender_id != #{userId}
    </select>

</mapper>
