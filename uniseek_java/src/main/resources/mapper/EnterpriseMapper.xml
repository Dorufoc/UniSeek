<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.uniseek.dao.EnterpriseMapper">

    <resultMap id="BaseResultMap" type="com.uniseek.entity.Enterprise">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="company_name" property="companyName"/>
        <result column="credit_code" property="creditCode"/>
        <result column="license_img_url" property="licenseImgUrl"/>
        <result column="industry" property="industry"/>
        <result column="region_id" property="regionId"/>
        <result column="description" property="description"/>
        <result column="audit_status" property="auditStatus"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <resultMap id="HotEnterpriseMap" type="com.uniseek.dto.HotEnterpriseVO">
        <id column="id" property="id"/>
        <result column="company_name" property="companyName"/>
        <result column="industry" property="industry"/>
        <result column="region_id" property="regionId"/>
        <result column="region_name" property="regionName"/>
        <result column="description" property="description"/>
        <result column="heat_score" property="heatScore"/>
        <result column="active_job_count" property="activeJobCount"/>
    </resultMap>

    <select id="selectHotEnterprises" resultMap="HotEnterpriseMap">
        SELECT
            e.id,
            e.company_name,
            e.industry,
            e.region_id,
            r.name AS region_name,
            e.description,
            ROUND(
                COALESCE(COUNT(DISTINCT ta.id), 0) * 0.5
                + COALESCE(SUM(CASE WHEN t.status = 1 THEN 1 ELSE 0 END), 0) * 0.3
                + COALESCE(SUM(t.total_quota), 0) * 0.2
            , 1) AS heat_score,
            COUNT(DISTINCT CASE WHEN t.status = 1 THEN t.id END) AS active_job_count
        FROM enterprise e
        LEFT JOIN task t ON t.enterprise_id = e.id AND t.status = 1
        LEFT JOIN task_application ta ON ta.task_id = t.id
        LEFT JOIN region r ON r.id = e.region_id
        WHERE e.audit_status = 1
        GROUP BY e.id
        HAVING heat_score > 0
        ORDER BY heat_score DESC
        LIMIT #{limit}
    </select>

    <select id="selectEnterprisePage" resultMap="BaseResultMap">
        SELECT e.*
        FROM enterprise e
        WHERE e.audit_status = 1
        <if test="keyword != null and keyword != ''">
            AND e.company_name LIKE CONCAT('%', #{keyword}, '%')
        </if>
        <if test="industry != null and industry != ''">
            AND e.industry = #{industry}
        </if>
        <if test="regionIds != null and regionIds.size() > 0">
            AND e.region_id IN
            <foreach item="rid" collection="regionIds" open="(" separator="," close=")">
                #{rid}
            </foreach>
        </if>
        <choose>
            <when test="sortBy == 'jobCount'">
                ORDER BY (SELECT COUNT(*) FROM task WHERE enterprise_id = e.id AND status = 1)
                <choose>
                    <when test="sortOrder == 'asc'">ASC</when>
                    <otherwise>DESC</otherwise>
                </choose>
            </when>
            <when test="sortBy == 'avgSalary'">
                ORDER BY (SELECT COALESCE(AVG((salary_min + salary_max) / 2.0), 0)
                          FROM task WHERE enterprise_id = e.id AND status = 1)
                <choose>
                    <when test="sortOrder == 'asc'">ASC</when>
                    <otherwise>DESC</otherwise>
                </choose>
            </when>
            <otherwise>
                ORDER BY e.create_time DESC
            </otherwise>
        </choose>
    </select>

</mapper>
